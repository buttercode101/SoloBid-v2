{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and business settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string" },
        "defaultTaxRate": { "type": "number" },
        "defaultMarkup": { "type": "number" },
        "defaultLaborRate": { "type": "number" },
        "terms": { "type": "string" },
        "invoicePrefix": { "type": "string" },
        "invoiceCount": { "type": "number" },
        "pdfStyle": { "type": "string" },
        "pdfFont": { "type": "string" },
        "defaultCurrency": { "type": "string", "enum": ["ZAR", "USD", "EUR", "GBP"] },
        "vatNumber": { "type": "string" },
        "saTaxInvoiceMode": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Client": {
      "title": "Client",
      "description": "Client contact information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "uid", "name"]
    },
    "Estimate": {
      "title": "Estimate",
      "description": "An estimate for a client",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "notes": { "type": "string" },
        "taxRate": { "type": "number" },
        "subtotal": { "type": "number" },
        "taxAmount": { "type": "number" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "vatAmount": { "type": "number" },
        "isMilestone": { "type": "boolean" },
        "progressPercent": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "approved", "converted"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "approvedAt": { "type": "string" },
        "signatureName": { "type": "string" }
      },
      "required": ["uid", "status", "createdAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quotation for a client",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "notes": { "type": "string" },
        "taxRate": { "type": "number" },
        "subtotal": { "type": "number" },
        "taxAmount": { "type": "number" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "vatAmount": { "type": "number" },
        "isMilestone": { "type": "boolean" },
        "progressPercent": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "approved", "converted"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "approvedAt": { "type": "string" },
        "signatureName": { "type": "string" }
      },
      "required": ["uid", "status", "createdAt"]
    },
    "LineItem": {
      "title": "LineItem",
      "description": "A line item in an estimate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "qty": { "type": "number" },
        "unitCost": { "type": "number" },
        "type": { "type": "string", "enum": ["labor", "material"] },
        "markupPercent": { "type": "number" }
      },
      "required": ["id", "description", "qty", "unitCost", "type"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice generated from an estimate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "estimateId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "vatAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] },
        "dueDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "paidAt": { "type": "string" }
      },
      "required": ["id", "uid", "status", "createdAt"]
    },
    "RecurringInvoice": {
      "title": "RecurringInvoice",
      "description": "A recurring invoice schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "yearly"] },
        "nextIssueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused"] },
        "total": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "uid", "frequency", "nextIssueDate", "status"]
    },
    "Template": {
      "title": "Template",
      "description": "A reusable estimate template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "lineItems": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "uid", "name"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A per-job expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "estimateId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "uid", "estimateId", "description", "amount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Clients"
    },
    "/estimates/{estimateId}": {
      "schema": { "$ref": "#/entities/Estimate" },
      "description": "Estimates"
    },
    "/estimates/{estimateId}/lineItems/{itemId}": {
      "schema": { "$ref": "#/entities/LineItem" },
      "description": "Estimate line items"
    },
    "/quotes/{quoteId}": {
      "schema": { "$ref": "#/entities/Quote" },
      "description": "Quotes"
    },
    "/quotes/{quoteId}/lineItems/{itemId}": {
      "schema": { "$ref": "#/entities/LineItem" },
      "description": "Quote line items"
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Invoices"
    },
    "/recurringInvoices/{recurringId}": {
      "schema": { "$ref": "#/entities/RecurringInvoice" },
      "description": "Recurring Invoices"
    },
    "/recurringInvoices/{recurringId}/lineItems/{itemId}": {
      "schema": { "$ref": "#/entities/LineItem" },
      "description": "Recurring Invoice line items"
    },
    "/templates/{templateId}": {
      "schema": { "$ref": "#/entities/Template" },
      "description": "Templates"
    },
    "/estimates/{estimateId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Per-job expenses"
    },
    "/quotes/{quoteId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Per-job expenses for quotes"
    }
  }
}
