rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth != null ? request.auth.uid == uid : (uid is string && uid.matches('^guest_.*'));
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Context-free operations
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidEstimate(data) {
      return data.uid is string && data.uid.size() > 0
        && data.clientName is string && data.clientName.size() <= 200
        && data.total is number && data.total >= 0
        && data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
    }

    function isValidQuote(data) {
      return data.uid is string && data.uid.size() > 0
        && data.clientName is string && data.clientName.size() <= 200
        && data.total is number && data.total >= 0
        && data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
    }

    function isClientApprovalUpdate() {
      return existing().status == 'sent'
        && incoming().status == 'approved'
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'signatureName', 'signatureDataUrl', 'approvedAt'])
        && incoming().signatureName is string
        && incoming().signatureName.size() > 0
        && incoming().signatureName.size() < 100
        && incoming().signatureDataUrl is string
        && incoming().signatureDataUrl.size() > 20
        && incoming().signatureDataUrl.size() < 500000
        && incoming().signatureDataUrl.matches('^data:image/(png|jpeg);base64,[A-Za-z0-9+/=]+$')
        && incoming().approvedAt is string;
    }

    function isClientRejectionUpdate() {
      return existing().status == 'sent'
        && incoming().status == 'rejected'
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'rejectionReason', 'rejectedAt'])
        && incoming().rejectionReason is string
        && incoming().rejectionReason.size() <= 1000
        && incoming().rejectedAt is string;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && (request.resource.data.uid == userId);
      allow update: if isOwner(userId) && (request.resource.data.uid == userId);
    }
    
    // Quotes (New)
    match /quotes/{quoteId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if (request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*')))
                    || resource.data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidQuote(incoming()) && isValidId(quoteId);
      allow update: if (
        (request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid)) && isValidQuote(incoming())
      ) || isClientApprovalUpdate() || isClientRejectionUpdate();
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }

    // Quotes Subcollections
    match /quotes/{quoteId}/lineItems/{itemId} {
      function quoteParentIsReadable() {
        return isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data.uid)
               || get(/databases/$(database)/documents/quotes/$(quoteId)).data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
      }
      
      allow read: if quoteParentIsReadable();
      allow write: if (
        (exists(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(getAfter(/databases/$(database)/documents/quotes/$(quoteId)).data.uid))
      );
    }

    match /quotes/{quoteId}/expenses/{expenseId} {
      allow read: if (
        (exists(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(getAfter(/databases/$(database)/documents/quotes/$(quoteId)).data.uid))
      );
      allow write: if (
        (exists(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/quotes/$(quoteId)) && isOwner(getAfter(/databases/$(database)/documents/quotes/$(quoteId)).data.uid))
      );
    }
    
    // Estimates
    match /estimates/{estimateId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if (request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*')))
                    || resource.data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidEstimate(incoming()) && isValidId(estimateId);
      allow update: if (
        (request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid)) && isValidEstimate(incoming())
      ) || isClientApprovalUpdate() || isClientRejectionUpdate();
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }
    
    // Line Items subcollection
    match /estimates/{estimateId}/lineItems/{itemId} {
      function parentIsReadable() {
        return isOwner(get(/databases/$(database)/documents/estimates/$(estimateId)).data.uid)
               || get(/databases/$(database)/documents/estimates/$(estimateId)).data.status in ['draft', 'sent', 'approved', 'rejected', 'converted', 'paid', 'overdue'];
      }
      
      allow read: if parentIsReadable();
      allow write: if (
        (exists(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(get(/databases/$(database)/documents/estimates/$(estimateId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(getAfter(/databases/$(database)/documents/estimates/$(estimateId)).data.uid))
      );
    }

    // Expenses subcollection
    match /estimates/{estimateId}/expenses/{expenseId} {
      allow read: if (
        (exists(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(get(/databases/$(database)/documents/estimates/$(estimateId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(getAfter(/databases/$(database)/documents/estimates/$(estimateId)).data.uid))
      );
      allow write: if (
        (exists(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(get(/databases/$(database)/documents/estimates/$(estimateId)).data.uid)) ||
        (existsAfter(/databases/$(database)/documents/estimates/$(estimateId)) && isOwner(getAfter(/databases/$(database)/documents/estimates/$(estimateId)).data.uid))
      );
    }

    // Expenses (Collection Group Support)
    match /{path=**}/expenses/{expenseId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*')));
      allow update: if request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid);
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }
    
    // Invoices
    match /invoices/{invoiceId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidId(invoiceId);
      allow update: if request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid);
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }
    
    // Templates
    match /templates/{templateId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidId(templateId);
      allow update: if request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid);
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }

    // Clients
    match /clients/{clientId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidId(clientId);
      allow update: if request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid);
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }

    // Recurring Invoices
    match /recurringInvoices/{recurringId} {
      allow list: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid != null);
      allow get: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
      allow create: if (request.auth != null ? request.resource.data.uid == request.auth.uid : (request.resource.data.uid is string && request.resource.data.uid.matches('^guest_.*'))) && isValidId(recurringId);
      allow update: if request.auth != null ? (resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid) : (resource.data.uid is string && resource.data.uid.matches('^guest_.*') && request.resource.data.uid == resource.data.uid);
      allow delete: if request.auth != null ? resource.data.uid == request.auth.uid : (resource.data.uid is string && resource.data.uid.matches('^guest_.*'));
    }
    
    match /recurringInvoices/{recurringId}/lineItems/{itemId} {
      allow read: if (
        (exists(/databases/$(database)/documents/recurringInvoices/$(recurringId)) && (
          request.auth != null ? get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid == request.auth.uid : (get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid is string && get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid.matches('^guest_.*'))
        )) ||
        (existsAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)) && (
          request.auth != null ? getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid == request.auth.uid : (getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid is string && getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid.matches('^guest_.*'))
        ))
      );
      allow write: if (
        (exists(/databases/$(database)/documents/recurringInvoices/$(recurringId)) && (
          request.auth != null ? get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid == request.auth.uid : (get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid is string && get(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid.matches('^guest_.*'))
        )) ||
        (existsAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)) && (
          request.auth != null ? getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid == request.auth.uid : (getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid is string && getAfter(/databases/$(database)/documents/recurringInvoices/$(recurringId)).data.uid.matches('^guest_.*'))
        ))
      );
    }

    // Global logs (system)
    match /cronLogs/{logId} {
      allow read: if false; // Only via Admin SDK
      allow write: if false;
    }
  }
}
