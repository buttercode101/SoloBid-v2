# Client-side (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Keep false for launch. Paystack is for SoloBid user subscriptions, not contractor/client invoice payments.
VITE_PAYSTACK_ENABLED=false
# VITE_PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Server-side
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Keep false for launch. Paystack webhooks should process SoloBid subscription events only.
PAYSTACK_ENABLED=false
# PAYSTACK_SECRET_KEY=your-paystack-secret-key
RESEND_API_KEY=your-resend-api-key

APP_ORIGIN=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CRON_SECRET=your-cron-secret-token

NODE_ENV=development
